{
  "name": "@luca-game/platform",
  "version": "0.1.0",
  "description": "Luca games collection: registry of 28 games (3 playable + 25 coming-soon), gallery UI, completion-check / resolve-steps API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./games": {
      "types": "./dist/games/index.d.ts",
      "import": "./dist/games/index.js"
    },
    "./games/*": {
      "types": "./dist/games/*/index.d.ts",
      "import": "./dist/games/*/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "echo \"@luca-game/platform: tests live per-game; run them inside packages/platform/src/games/*\" && exit 0",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^11.0.0 || ^12.0.0 || ^13.0.0"
  },
  "dependencies": {
    "@luca-game/engine": "0.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^13.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": ["games", "platform", "puzzles", "react", "luca"],
  "license": "MIT"
}