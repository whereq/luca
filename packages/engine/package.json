{
  "name": "@luca-game/engine",
  "version": "0.1.0",
  "description": "Generic React state machine for running any game. Framework-coupled to React but UI-agnostic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "test": "echo \"@luca-game/engine: no tests (logic lives in games)\" && exit 0",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-i18next": "^11.0.0 || ^12.0.0 || ^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0 || ^17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^13.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": ["games", "engine", "state-machine", "react", "luca", "open-source"],
  "license": "MIT",
  "author": "whereq <https://github.com/whereq>",
  "homepage": "https://github.com/whereq/luca#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whereq/luca.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/whereq/luca/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}