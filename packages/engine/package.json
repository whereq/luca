{
  "name": "@luca-game/engine",
  "version": "0.1.0",
  "description": "Generic React state machine for running any game. Framework-coupled to React but UI-agnostic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "echo \"@luca-game/engine: no tests (logic lives in games)\" && exit 0",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": ["games", "engine", "state-machine", "react", "luca"],
  "license": "MIT"
}